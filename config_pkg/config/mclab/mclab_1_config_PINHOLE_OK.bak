%YAML:1.0

# Horloges et Topics
imu_topic: "/alphasense_driver_ros/imu"
image_topic: "/alphasense_driver_ros/cam0"
output_path: "/home/melanie/rov_ws"

# Modèle de Caméra Standard et Stable (Validation par PinholeCamera.cc)
model_type: "PINHOLE"
camera_name: "cam0_underwater"
image_width: 720
image_height: 540

# Paramètres de Projection standard (fx, fy, cx, cy)
projection_parameters:
   fx: 460.1163446727443
   fy: 460.4372977453345
   cx: 357.8825573770236
   cy: 266.43728860156045
   k1: 0.04816514299784573
   k2: 0.1707359987229406
   p1: -0.30080163056061726
   p2: 0.47220233022405056

# Extrinsèques Caméra -> IMU (T_ic)
estimate_extrinsic: 0
extrinsicRotation: !!opencv-matrix
   rows: 3
   cols: 3
   dt: d
   data: [ 0.00574588594214509, 0.005987169593925534, 0.9999655687047404,
           0.9999832777219597, 0.000620632174701985, -0.0057497036576725224,
           -0.0006550352564456685, 0.9999818841438872, -0.005983503393123035 ]
extrinsicTranslation: !!opencv-matrix
   rows: 3
   cols: 1
   dt: d
   data: [ 0.04839478722203644, 0.0479978115139549, -0.009770661863198023 ]

# Paramètres de Bruit IMU
acc_n: 0.0186
gyr_n: 0.000587
acc_w: 0.00433
gyr_w: 0.002866
g_norm: 9.81

# Configuration Front-end
max_cnt: 150
min_dist: 30
freq: 10
F_threshold: 1.0
show_track: 1
equalize: 0
fisheye: 0               # Désactivé pour le mode Pinhole standard

# Optimisation
max_solver_time: 0.04
max_num_iterations: 8
keyframe_parallax: 10.0

# Divers
loop_closure: 0
estimate_td: 0
td: 0.0
rolling_shutter: 0
